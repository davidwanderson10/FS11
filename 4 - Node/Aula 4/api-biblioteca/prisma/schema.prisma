// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model autores {
  id  Int @id @default(autoincrement())
  nome String @db.VarChar(200)
}

model categorias {
  id  Int @id @default(autoincrement())
  nome String @db.VarChar(200)
}

